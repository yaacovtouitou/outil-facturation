{% extends 'base.html.twig' %}

{% block title %}Clients{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Clients</h1>
            <p class="text-muted">Gérez votre base de clients.</p>
        </div>
        <a href="{{ path('client_new') }}" class="btn btn-primary shadow-sm">
            <i class="bi bi-person-plus"></i> Ajouter un client
        </a>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                <tr>
                    <th class="ps-4">Nom complet</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for client in clients %}
                    <tr>
                        <td class="ps-4">
                            <div class="d-flex align-items-center">
                                <div class="avatar bg-primary bg-opacity-10 text-primary rounded-circle text-center me-3 fw-bold" style="width:40px; height:40px; line-height:40px;">
                                    {{ client.nom|first|upper }}{{ client.prenom|first|upper }}
                                </div>
                                <div>
                                    <div class="fw-bold text-dark">{{ client.nom }} {{ client.prenom }}</div>
                                    <div class="small text-muted">ID: #{{ client.id }}</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <a href="mailto:{{ client.email }}" class="text-decoration-none text-muted">
                                <i class="bi bi-envelope me-2"></i>{{ client.email }}
                            </a>
                        </td>
                        <td>
                            <span class="text-muted"><i class="bi bi-telephone me-2"></i>{{ client.telephone }}</span>
                        </td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a href="{{ path('client_edit', {id: client.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="{{ path('client_delete', {id: client.id}) }}" class="btn btn-sm btn-outline-danger" onclick="return confirm('Supprimer ce client ?');" title="Supprimer">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <div class="text-muted">
                                <i class="bi bi-people fs-1 d-block mb-3 opacity-50"></i>
                                Aucun client enregistré.
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
