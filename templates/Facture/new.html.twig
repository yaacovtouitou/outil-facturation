{% extends 'base.html.twig' %}

{% block title %}Nouvelle Facture{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 fw-bold mb-0">Nouvelle Facture</h1>
                <a href="{{ path('facture_list') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Retour
                </a>
            </div>

            <form method="post" class="needs-validation">
                <div class="row g-4">
                    <!-- Colonne Gauche : Infos Générales -->
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white py-3">
                                <h5 class="mb-0 text-primary"><i class="bi bi-info-circle me-2"></i>Informations</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-4">
                                    <label class="form-label text-muted small text-uppercase fw-bold">Client</label>
                                    <select name="client" class="form-select form-select-lg" required>
                                        <option value="" disabled selected>Choisir un client...</option>
                                        {% for client in clients %}
                                            <option value="{{ client.id }}">{{ client.nom }} {{ client.prenom }}</option>
                                        {% endfor %}
                                    </select>
                                    <div class="form-text mt-2">
                                        Client introuvable ? <a href="{{ path('client_new') }}" class="text-decoration-none">Créer un nouveau client</a>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label text-muted small text-uppercase fw-bold">Statut initial</label>
                                    <select name="statut" class="form-select">
                                        <option value="en_attente">En attente</option>
                                        <option value="payee">Payée</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Colonne Droite : Prestations -->
                    <div class="col-md-8">
                        <div class="card border-0 shadow-sm h-100">
                            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                                <h5 class="mb-0 text-primary"><i class="bi bi-list-check me-2"></i>Prestations</h5>
                                <button type="button" class="btn btn-sm btn-outline-primary" onclick="ajouterPrestation()">
                                    <i class="bi bi-plus-circle"></i> Ajouter une ligne
                                </button>
                            </div>
                            <div class="card-body bg-light">
                                <div id="prestations-container">
                                    <!-- Les lignes seront ajoutées ici -->
                                    <div class="prestation-item card border-0 mb-3 shadow-sm">
                                        <div class="card-body p-3">
                                            <div class="row g-2 align-items-end">
                                                <div class="col-md-6">
                                                    <label class="form-label small text-muted">Description</label>
                                                    <input type="text" name="prestations[0][description]" class="form-control" placeholder="Ex: Création site web" required>
                                                </div>
                                                <div class="col-md-3">
                                                    <label class="form-label small text-muted">Prix Unit. (€)</label>
                                                    <input type="number" step="0.01" name="prestations[0][prix]" class="form-control text-end" placeholder="0.00" required>
                                                </div>
                                                <div class="col-md-2">
                                                    <label class="form-label small text-muted">Qté</label>
                                                    <input type="number" name="prestations[0][quantite]" class="form-control text-center" value="1" required>
                                                </div>
                                                <div class="col-md-1 text-end">
                                                    <button type="button" class="btn btn-link text-danger p-0" onclick="this.closest('.prestation-item').remove()" title="Supprimer">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer bg-white py-3 text-end">
                                <button type="submit" class="btn btn-success btn-lg px-5 shadow-sm">
                                    <i class="bi bi-check-lg me-2"></i> Créer la facture
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <script>
        let index = 1;
        function ajouterPrestation() {
            const container = document.getElementById('prestations-container');
            const div = document.createElement('div');
            div.classList.add('prestation-item', 'card', 'border-0', 'mb-3', 'shadow-sm');
            div.innerHTML = `
                <div class="card-body p-3">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-6">
                            <input type="text" name="prestations[${index}][description]" class="form-control" placeholder="Description" required>
                        </div>
                        <div class="col-md-3">
                            <input type="number" step="0.01" name="prestations[${index}][prix]" class="form-control text-end" placeholder="Prix" required>
                        </div>
                        <div class="col-md-2">
                            <input type="number" name="prestations[${index}][quantite]" class="form-control text-center" value="1" required>
                        </div>
                        <div class="col-md-1 text-end">
                            <button type="button" class="btn btn-link text-danger p-0" onclick="this.closest('.prestation-item').remove()">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>`;
            container.appendChild(div);
            index++;
        }
    </script>
{% endblock %}
