{% extends 'base.html.twig' %}

{% block title %}Dashboard - InvoiceEasy{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 fw-bold text-dark mb-1">Tableau de bord</h1>
            <p class="text-muted">Bienvenue sur votre espace de gestion.</p>
        </div>
        <a href="{{ path('facture_new') }}" class="btn btn-success shadow-sm">
            <i class="bi bi-plus-lg"></i> Nouvelle Facture
        </a>
    </div>

    <!-- Stats Cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-primary bg-opacity-10 p-3 rounded-3 text-primary me-3">
                            <i class="bi bi-people fs-4"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1">Total Clients</h6>
                            <h3 class="fw-bold mb-0">{{ clients|length }}</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-success bg-opacity-10 p-3 rounded-3 text-success me-3">
                            <i class="bi bi-file-earmark-check fs-4"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1">Factures Émises</h6>
                            <h3 class="fw-bold mb-0">{{ factures|length }}</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center">
                        <div class="bg-warning bg-opacity-10 p-3 rounded-3 text-warning me-3">
                            <i class="bi bi-cash-stack fs-4"></i>
                        </div>
                        <div>
                            <h6 class="text-muted mb-1">Chiffre d'affaires (Est.)</h6>
                            <h3 class="fw-bold mb-0">
                                {% set ca = 0 %}
                                {% for f in factures %}
                                    {% set ca = ca + f.total %}
                                {% endfor %}
                                {{ ca|number_format(0, ',', ' ') }} €
                            </h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Invoices Table -->
    <div class="card border-0">
        <div class="card-header bg-white border-0 py-3 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold">Dernières factures</h5>
            <a href="{{ path('facture_list') }}" class="btn btn-sm btn-outline-primary">Voir tout</a>
        </div>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="bg-light">
                <tr>
                    <th class="ps-4">#ID</th>
                    <th>Client</th>
                    <th>Date</th>
                    <th>Statut</th>
                    <th class="text-end">Montant</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for facture in factures %}
                    <tr>
                        <td class="ps-4 fw-bold text-primary">#{{ '%05d'|format(facture.id) }}</td>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="avatar bg-light rounded-circle text-center me-2" style="width:35px; height:35px; line-height:35px;">
                                    {{ facture.client.nom|first|upper }}
                                </div>
                                <div>
                                    <div class="fw-bold">{{ facture.client.nom }} {{ facture.client.prenom }}</div>
                                    <div class="small text-muted">{{ facture.client.email }}</div>
                                </div>
                            </div>
                        </td>
                        <td class="text-muted">{{ facture.dateEmission|date('d M Y') }}</td>
                        <td>
                            {% if facture.statut == 'payee' %}
                                <span class="badge bg-success bg-opacity-10 text-success">Payée</span>
                            {% else %}
                                <span class="badge bg-warning bg-opacity-10 text-warning">En attente</span>
                            {% endif %}
                        </td>
                        <td class="text-end fw-bold">{{ facture.total|number_format(2, ',', ' ') }} €</td>
                        <td class="text-end pe-4">
                            <div class="btn-group">
                                <a href="{{ path('facture_pdf', {'id': facture.id}) }}" class="btn btn-sm btn-light text-dark" title="Télécharger PDF"><i class="bi bi-download"></i></a>
                                <a href="{{ path('facture_edit', {'id': facture.id}) }}" class="btn btn-sm btn-light text-primary" title="Modifier"><i class="bi bi-pencil"></i></a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-inbox fs-1 d-block mb-3"></i>
                            Aucune facture trouvée
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
